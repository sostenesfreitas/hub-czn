{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-open",
    "opener:allow-open-url",
    "dialog:allow-save",
    "fs:allow-write-text-file"
  ]
}
