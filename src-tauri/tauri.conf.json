{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hub-czn",
  "version": "0.3.1",
  "identifier": "com.hubczn.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "python check_sidecar_version.py && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hub CZN",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/hub-czn-api"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis/installer-hooks.nsi"
      }
    }
  }
}
